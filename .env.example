# .env.example
# Generated by Tesla export — copy to .env and fill in real values.
# NEVER commit .env to version control.


# ── System ───────────────────────────────────────────────────────
# Enforce strict config validation at startup (true/false)
CONFIG_STRICT_MODE=false
# System display name — falls back to config/system.json if unset
SYSTEM_NAME=Odin
# OpenClaw binary path override (default: resolved via PATH)
OPENCLAW_BIN=openclaw
# Git author email for Tesla export commits
GIT_EMAIL=tesla@openclaw.local
# Git author name for Tesla export commits
GIT_NAME=Tesla Export Bot

# ── GitHub ───────────────────────────────────────────────────────
# GitHub PAT with repo write access — required for push
GITHUB_TOKEN=ghp_your_token_here
# GitHub username (used to build remote URLs)
GITHUB_USERNAME=your_github_username
# Optional: override remote URL for odin-core repo
GITHUB_REMOTE_ODIN_CORE=
# Optional: override remote URL for odin-agents repo
GITHUB_REMOTE_ODIN_AGENTS=

# ── Discord ──────────────────────────────────────────────────────
# Main Odin Discord bot token
DISCORD_BOT_TOKEN=your_discord_bot_token
# Tesla Discord bot token (if Tesla has a dedicated bot)
TESLA_DISCORD_BOT_TOKEN=your_tesla_bot_token

# ── Telegram ─────────────────────────────────────────────────────
# Telegram bot token for usage-monitor alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Telegram chat ID for usage-monitor alerts
TELEGRAM_CHAT_ID=your_chat_id

# ── LLM Providers ────────────────────────────────────────────────
# Anthropic API key (for API-key auth, not needed with OAuth)
ANTHROPIC_API_KEY=sk-ant-your-key-here
# OpenAI API key (optional provider)
OPENAI_API_KEY=sk-your-openai-key
# Groq API key
GROQ_API_KEY=your_groq_key
# MiniMax API key
MINIMAX_API_KEY=your_minimax_key
# Kimi (Moonshot) API key
KIMI_API_KEY=your_kimi_key
# Moonshot API key alias for Kimi
MOONSHOT_API_KEY=your_moonshot_key
# NVIDIA API key for Nemotron models
NVIDIA_API_KEY=your_nvidia_key
