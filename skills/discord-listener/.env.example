# Discord Listener Bot Configuration

# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_bot_token_here

# Discord Server ID (right-click server → Copy Server ID)
DISCORD_GUILD_ID=1477047631950643244

# Agent channels to monitor (comma-separated)
AGENT_CHANNELS=apollo,buddha,hermes,chronus,hercules,zeus,tesla,beelzebub,adam,sasaki,hades,shiva,qin

# Workspace path (where SOUL.md, AGENTS.md, etc. are stored)
WORKSPACE_PATH=/Users/odinclaw/.openclaw-odin/workspace

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
